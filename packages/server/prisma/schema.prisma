// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
}

model Artist {
    id        Int      @id @default(autoincrement())
    name      String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    Album     Album[]
    Music     Music[]
}

model Album {
    id            Int      @id @default(autoincrement())
    name          String
    cover         String
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    publishedYear String
    Music         Music[]
    Artist        Artist   @relation(fields: [artistId], references: [id])
    artistId      Int
}

model Genre {
    id        Int      @id @default(autoincrement())
    name      String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    Music     Music[]
}

model Tag {
    id             Int            @id @default(autoincrement())
    scopeKey       String         @default("local")
    name           String
    normalizedName String
    color          String?
    description    String?
    order          Int            @default(0)
    createdAt      DateTime       @default(now())
    updatedAt      DateTime       @updatedAt
    MusicTag       MusicTag[]
    SmartViewTag   SmartViewTag[]

    @@unique([scopeKey, normalizedName])
    @@index([scopeKey, order])
    @@index([scopeKey, updatedAt])
}

model Music {
    id            Int             @id @default(autoincrement())
    name          String
    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt
    Album         Album           @relation(fields: [albumId], references: [id])
    Artist        Artist          @relation(fields: [artistId], references: [id])
    albumId       Int
    artistId      Int
    filePath      String
    contentHash   String?
    hashVersion   Int?
    duration      Float
    codec         String
    container     String
    bitrate       Float
    sampleRate    Float
    playCount     Int             @default(0)
    lastPlayedAt  DateTime?
    lastSeenAt    DateTime?
    missingSinceAt DateTime?
    syncStatus    String          @default("active")
    totalPlayedMs Float           @default(0)
    trackNumber   Int
    Genre         Genre[]
    MusicLike     MusicLike[]
    MusicHate     MusicHate[]
    MusicTag      MusicTag[]
    PlaybackEvent PlaybackEvent[]
    PlaybackQueueItem PlaybackQueueItem[]
    PlaybackSession PlaybackSession[]
    PlaylistMusic PlaylistMusic[]

    @@index([contentHash])
    @@index([syncStatus, missingSinceAt])
}

model MusicTag {
    id        Int      @id @default(autoincrement())
    source    String   @default("manual")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    Music     Music    @relation(fields: [musicId], references: [id], onDelete: Cascade)
    musicId   Int
    Tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
    tagId     Int

    @@unique([musicId, tagId])
    @@index([tagId, musicId])
}

model SmartView {
    id             Int            @id @default(autoincrement())
    scopeKey       String         @default("local")
    name           String
    normalizedName String
    tagMode        String         @default("all")
    filterVersion  Int            @default(1)
    filterJson     String?
    sortKey        String?
    order          Int            @default(0)
    createdAt      DateTime       @default(now())
    updatedAt      DateTime       @updatedAt
    SmartViewTag   SmartViewTag[]

    @@unique([scopeKey, normalizedName])
    @@index([scopeKey, order])
    @@index([scopeKey, updatedAt])
}

model SmartViewTag {
    id          Int       @id @default(autoincrement())
    polarity    String    @default("include")
    order       Int       @default(0)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    SmartView   SmartView @relation(fields: [smartViewId], references: [id], onDelete: Cascade)
    smartViewId Int
    Tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
    tagId       Int

    @@unique([smartViewId, tagId])
    @@index([tagId, smartViewId])
    @@index([smartViewId, order])
}

model SyncReport {
    id             Int              @id @default(autoincrement())
    createdAt      DateTime         @default(now())
    updatedAt      DateTime         @updatedAt
    startedAt      DateTime
    completedAt    DateTime?
    status         String
    force          Boolean          @default(false)
    scannedFiles   Int              @default(0)
    indexedFiles   Int              @default(0)
    createdCount   Int              @default(0)
    movedCount     Int              @default(0)
    duplicateCount Int              @default(0)
    missingCount   Int              @default(0)
    Item           SyncReportItem[]

    @@index([createdAt])
    @@index([status, createdAt])
}

model SyncReportItem {
    id               Int        @id @default(autoincrement())
    createdAt        DateTime   @default(now())
    kind             String
    musicId          Int?
    musicName        String
    filePath         String
    previousFilePath String?
    SyncReport       SyncReport @relation(fields: [syncReportId], references: [id], onDelete: Cascade)
    syncReportId     Int

    @@index([syncReportId, kind])
}

model PlaybackEvent {
    id             Int      @id @default(autoincrement())
    createdAt      DateTime @default(now())
    startedAt      DateTime
    endedAt        DateTime
    playedMs       Float
    completionRate Float
    countedAsPlay  Boolean  @default(false)
    source         String
    clientSessionId String? @unique
    connectorId    String?
    Music          Music    @relation(fields: [musicId], references: [id])
    musicId        Int

    @@index([musicId, endedAt])
}

model PlaybackSession {
    id                   Int      @id @default(autoincrement())
    scopeKey             String   @unique @default("local")
    state                String   @default("stopped")
    activeDeviceId       String?
    activeDeviceSequence Int      @default(0)
    currentMusicId       Int?
    positionMs           Float    @default(0)
    positionUpdatedAt    DateTime @default(now())
    startedAt            DateTime?
    revision             Int      @default(0)
    createdAt            DateTime @default(now())
    updatedAt            DateTime @updatedAt
    Music                Music?   @relation(fields: [currentMusicId], references: [id], onDelete: SetNull)
    Queue                PlaybackQueue?

    @@index([currentMusicId])
}

model PlaybackQueue {
    id           Int                 @id @default(autoincrement())
    sessionId    Int                 @unique
    currentIndex Int?
    shuffle      Boolean             @default(false)
    repeatMode   String              @default("none")
    revision     Int                 @default(0)
    createdAt    DateTime            @default(now())
    updatedAt    DateTime            @updatedAt
    Session      PlaybackSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    Item         PlaybackQueueItem[]
}

model PlaybackQueueItem {
    id          Int           @id @default(autoincrement())
    queueId     Int
    musicId     Int
    order       Int
    sourceOrder Int?
    Queue       PlaybackQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
    Music       Music         @relation(fields: [musicId], references: [id], onDelete: Cascade)

    @@unique([queueId, musicId])
    @@unique([queueId, order])
    @@index([musicId])
}

model MusicLike {
    id        Int      @id @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    Music     Music    @relation(fields: [musicId], references: [id])
    musicId   Int
}

model MusicHate {
    id        Int      @id @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    Music     Music    @relation(fields: [musicId], references: [id])
    musicId   Int
}

model Playlist {
    id            Int             @id @default(autoincrement())
    name          String
    order         Int             @default(0)
    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt
    PlaylistMusic PlaylistMusic[]
}

model PlaylistMusic {
    id         Int      @id @default(autoincrement())
    order      Int      @default(0)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    Music      Music    @relation(fields: [musicId], references: [id])
    musicId    Int
    Playlist   Playlist @relation(fields: [playlistId], references: [id])
    playlistId Int
}
