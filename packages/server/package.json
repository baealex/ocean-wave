{
    "name": "ocean-wave-server",
    "version": "1.0.0",
    "description": "Ocean Wave server",
    "scripts": {
        "benchmark:rediscovery": "ts-node script/benchmark-library-rediscovery.ts",
        "postinstall": "prisma generate",
        "dev": "cross-env PORT=44100 ts-node script/_dev.ts",
        "dev:client": "pnpm --filter ocean-wave-client dev",
        "dev:with": "pnpm --workspace-root dev",
        "start": "cross-env PORT=44100 ts-node script/_start.ts",
        "build": "tsc",
        "build:client": "pnpm --filter ocean-wave-client build",
        "type-check": "tsc --noEmit",
        "lint": "pnpm --workspace-root exec biome lint packages/server/src packages/server/script packages/server/cli packages/server/jest.config.ts packages/server/jest.setup.ts",
        "test": "DATABASE_URL=file:./test.sqlite3 ts-node script/_test.ts",
        "create-schema": "ts-node cli/create-schema.ts",
        "create-component": "ts-node cli/create-component.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/baealex/ocean-wave.git"
    },
    "author": "",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/baealex/ocean-wave/issues"
    },
    "homepage": "https://github.com/baealex/ocean-wave#readme",
    "dependencies": {
        "@baejino/auth": "^0.1.1",
        "@prisma/adapter-better-sqlite3": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "bcrypt": "^6.0.0",
        "better-sqlite3": "^12.11.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.6.0",
        "express-winston": "^4.2.0",
        "fluent-ffmpeg": "^2.1.3",
        "graphql-http": "^1.22.4",
        "music-metadata": "^11.13.0",
        "prisma": "^7.8.0",
        "sharp": "^0.35.3",
        "socket.io": "^4.8.3",
        "taglib-wasm": "^1.5.0",
        "ts-node": "^10.9.2",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@graphql-tools/schema": "^10.0.36",
        "@graphql-tools/utils": "^11.2.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/express": "^5.0.6",
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/jest": "^30.0.0",
        "@types/node": "^26.1.1",
        "@types/supertest": "^7.2.0",
        "cross-env": "^10.1.0",
        "jest": "^30.4.2",
        "nodemon": "^3.1.14",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.3"
    }
}
