# Ocean Wave deployment environment example.
# Copy this file to .env for Docker Compose, then fill the blank required values.

# Required for Docker Compose password mode. The server fails closed when auth is not configured.
OCEAN_WAVE_AUTH_PASSWORD=
OCEAN_WAVE_SESSION_SECRET=

# Only set this to true if you intentionally want no-auth access.
# Do not enable it together with OCEAN_WAVE_AUTH_PASSWORD.
OCEAN_WAVE_ALLOW_INSECURE_NO_AUTH=

# Container paths used by docker-compose.yml volume mounts.
OCEAN_WAVE_MUSIC_PATH=/music
OCEAN_WAVE_CACHE_PATH=/cache
DATABASE_URL=file:/data/db.sqlite3

# HTTP port used by the server and exposed by Docker Compose.
PORT=44100
